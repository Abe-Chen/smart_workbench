# 复制这个文件为 .env 并填入真实值。.env 不会进 git。
#
# === 火山引擎方舟（豆包大模型） —— LLM ===
# 在 https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint 查
VOLC_ARK_API_KEY=
DOUBAO_ENDPOINT_ID=

# === 讯飞开放平台 —— 唤醒词 / ASR / TTS 共用一套凭据 ===
# 在 https://console.xfyun.cn 创建应用，开通"语音唤醒"+"语音听写 IAT"+"在线语音合成"
# 唤醒词需要在控制台为该应用配置自定义"小治小治"
XF_APP_ID=
XF_API_KEY=
XF_API_SECRET=

# === 高德开放平台 —— IP 定位（让小治知道用户所在城市） ===
# 在 https://lbs.amap.com 申请 Web 服务 Key
AMAP_KEY=
